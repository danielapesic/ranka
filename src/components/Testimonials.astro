---
import { reviews, ratingStats, googleProfileUrl } from '../data/reviews.ts'

const hrMonths = [
  'siječanj','veljača','ožujak','travanj','svibanj','lipanj',
  'srpanj','kolovoz','rujan','listopad','studeni','prosinac',
]

function formatDate(iso: string): string {
  const d = new Date(iso)
  return `${hrMonths[d.getMonth()]} ${d.getFullYear()}`
}

// Format rating with Croatian comma decimal
const ratingDisplay = ratingStats.ratingValue.toFixed(1).replace('.', ',')
---
<section id="recenzije" class="section-pt pb-24 lg:pb-32" aria-labelledby="testimonials-heading">
  <div class="container-wide">

    <!-- Header -->
    <div class="mb-8 fade-up">
      <p class="eyebrow">Recenzije</p>
      <h2 id="testimonials-heading" class="heading-lg mb-5">
        Što kažu naši klijenti
      </h2>

      <!-- Aggregate rating line -->
      <div class="flex items-center gap-3 flex-wrap">
        <!-- Stars -->
        <div class="flex gap-0.5" aria-label={`Prosječna ocjena: ${ratingDisplay} od 5`} role="img">
          {Array.from({ length: 5 }).map(() => (
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
              <polygon
                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
                fill="#C8923D"
                stroke="none"
              />
            </svg>
          ))}
        </div>
        <span class="font-semibold text-charcoal">{ratingDisplay}</span>
        <span class="text-sm text-stone">
          na temelju {ratingStats.reviewCount} recenzija na Googleu
        </span>
      </div>
    </div>

    <!-- Review cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {reviews.map((r, i) => (
        <figure
          class={`rounded-xl border border-pebble bg-white p-6 flex flex-col gap-4 fade-up fade-up-delay-${Math.min(i + 1, 4)}`}
          aria-label={`Recenzija od ${r.author}`}
          itemscope
          itemtype="https://schema.org/Review"
        >
          <!-- Top row: avatar + stars -->
          <div class="flex items-center justify-between">
            <!-- Initials avatar -->
            <div
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-sage-50 text-sm font-semibold text-sage-600 select-none"
              aria-hidden="true"
            >
              {r.initials}
            </div>

            <!-- Stars -->
            <div
              class="flex gap-0.5"
              aria-label={`Ocjena: ${r.rating} od 5 zvjezdica`}
              role="img"
              itemprop="reviewRating"
              itemscope
              itemtype="https://schema.org/Rating"
            >
              <meta itemprop="ratingValue" content={String(r.rating)} />
              <meta itemprop="bestRating" content="5" />
              {Array.from({ length: 5 }).map((_, si) => (
                <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
                  <polygon
                    points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
                    fill={si < r.rating ? '#C8923D' : '#E5E7EB'}
                    stroke="none"
                  />
                </svg>
              ))}
            </div>
          </div>

          <!-- Quote -->
          <blockquote class="flex-1" itemprop="reviewBody">
            <p class="text-stone leading-relaxed text-sm italic">
              &ldquo;{r.text}&rdquo;
            </p>
          </blockquote>

          <!-- Author + date -->
          <figcaption class="pt-4 border-t border-pebble text-xs text-stone">
            <span class="font-semibold text-charcoal not-italic" itemprop="author" itemscope itemtype="https://schema.org/Person">
              <span itemprop="name">{r.author}</span>
            </span>
            <span aria-hidden="true"> · </span>
            <time datetime={r.date} itemprop="datePublished">
              {formatDate(r.date)}
            </time>
            <!-- Google attribution icon -->
            <svg class="inline-block ml-1.5 mb-0.5" width="10" height="10" viewBox="0 0 24 24" aria-label="Google recenzija">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </figcaption>
        </figure>
      ))}
    </div>

    <!-- View all on Google CTA -->
    <div class="mt-8 text-center fade-up">
      <a
        href={googleProfileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-sage-500 hover:text-sage-600 font-medium transition-colors duration-200"
        aria-label="Pročitajte sve recenzije na Googleu (otvara se u novom prozoru)"
      >
        Pročitajte sve recenzije na Googleu
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

  </div>
</section>
