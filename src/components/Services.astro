---
// Services — full-image overlay cards h-100
const services = [
  {
    image: '/images/service-masaza.jpg',
    alt: 'Masaža za žene i muškarce u Salon Ranka',
    category: 'Masaža',
    title: 'Masaža',
    description: 'Opuštajuća masaža za žene i muškarce, prilagođena vašim potrebama — parcijalna ili cijelo tijelo.',
  },
  {
    image: '/images/service-medicinska.jpg',
    alt: 'Medicinska masaža za ublažavanje bolova',
    category: 'Terapija',
    title: 'Medicinska masaža',
    description: 'Ciljana terapija za bolove u leđima, vratu i ramenima — parcijalna ili cijelo tijelo.',
  },
  {
    image: '/images/service-antistress.jpg',
    alt: 'Antistress terapija i cupping masaža',
    category: 'Terapija',
    title: 'Antistress i cupping',
    description: 'Intenzivna tehnika dubokog opuštanja za redukciju stresa, napetosti i umora.',
  },
  {
    image: '/images/service-kozmetika.jpg',
    alt: 'Kozmetički tretman lica i leđa',
    category: 'Kozmetika',
    title: 'Kozmetika',
    description: 'Profesionalni tretmani lica i leđa za zdravu, čistu i sjajnu kožu.',
  },
  {
    image: '/images/service-depilacija.jpg',
    alt: 'Depilacija hladnim voskom',
    category: 'Depilacija',
    title: 'Depilacija voskom',
    description: 'Precizna i dugotrajna depilacija hladnim voskom za sve dijelove tijela.',
  },
  {
    image: '/images/service-obrve.jpg',
    alt: 'Oblikovanje i bojenje obrva i trepavica',
    category: 'Kozmetika',
    title: 'Obrve i trepavice',
    description: 'Korekcija oblika, bojenje obrva i trepavica za savršeno definiran pogled.',
  },
]
---
<section id="usluge" class="section-pt" aria-labelledby="services-heading">
  <div class="container-wide text-center">
    <h2 id="services-heading" class="heading-lg mb-2">Naše usluge</h2>
    <p class="mx-auto mb-12 max-w-xl text-sm text-stone md:text-base">
      Naši iskusni terapeuti pružaju tretmane prilagođene vašim individualnim potrebama.
    </p>

    <div class="grid gap-6 md:grid-cols-3">
      {services.map((s) => (
        <article
          class="group relative flex h-100 flex-col justify-end overflow-hidden rounded-xl"
          aria-label={s.title}
        >
          <img
            src={s.image}
            alt={s.alt}
            class="absolute inset-0 h-full w-full object-cover transition-all duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black/40 transition-all group-hover:bg-black/50" aria-hidden="true"></div>
          <div class="relative z-10 p-6 text-left text-white">
            <p class="mb-1 text-xs tracking-wider uppercase opacity-80">{s.category}</p>
            <h3 class="mb-2 text-xl font-semibold md:text-2xl">{s.title}</h3>
            <p class="text-sm leading-snug opacity-90">{s.description}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA to full price list -->
    <div class="mt-12 text-center fade-up">
      <a href="/cjenik" class="btn-outline-sage">
        Pogledajte sve usluge i cijene
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

  </div>
</section>
