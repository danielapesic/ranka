---
// About — centered text with floating circular images (matches Revaya structure exactly)
---
<section class="relative section-pt" aria-labelledby="about-heading">
  <div class="container-wide">

    <!-- Centered text block (z-10 to sit above floating circles) -->
    <div class="relative z-10 mx-auto max-w-4xl text-center fade-up">
      <p class="eyebrow">Otkrijte spokoj u svakom trenutku</p>
      <h2 id="about-heading" class="heading-lg text-charcoal mb-6">
        Probudite osjetila, <br /> <span class="text-sage-500">vratite mir</span>
      </h2>
      <p class="mx-auto mb-10 max-w-xl leading-relaxed text-stone">
        Salon Ranka je mjesto gdje moderna njega susreće tihu posvećenost detalju. Naši tretmani osmišljeni su kako bi vam vratili energiju, smirili um i ostavili vas osvježenima — bilo da tražite opuštanje, ublažavanje napetosti ili podršku u oporavku.
      </p>
      <a href="tel:+38516110777" class="btn-primary" aria-label="Nazovite za termin: +385 1 6110 777">
        Nazovite za termin
      </a>
    </div>

    <!-- Floating circles — desktop only -->
    <div class="pointer-events-none absolute inset-0 hidden lg:block" aria-hidden="true">
      <div class="absolute top-1/4 left-[5%] h-48 w-48 overflow-hidden rounded-full border-4 border-white shadow-lg">
        <img src="/images/about-1.jpg" alt="" class="h-full w-full object-cover" loading="lazy" />
      </div>
      <div class="absolute top-1/2 left-[15%] h-32 w-32 -translate-y-1/2 overflow-hidden rounded-full border-4 border-white shadow-lg">
        <img src="/images/about-2.jpg" alt="" class="h-full w-full object-cover" loading="lazy" />
      </div>
      <div class="absolute bottom-1/4 left-[5%] h-40 w-40 overflow-hidden rounded-full border-4 border-white shadow-lg">
        <img src="/images/about-3.jpg" alt="" class="h-full w-full object-cover" loading="lazy" />
      </div>
      <div class="absolute top-1/4 right-[5%] h-40 w-40 overflow-hidden rounded-full border-4 border-white shadow-lg">
        <img src="/images/about-4.jpg" alt="" class="h-full w-full object-cover" loading="lazy" />
      </div>
      <div class="absolute top-1/2 right-[15%] h-32 w-32 -translate-y-1/2 overflow-hidden rounded-full border-4 border-white shadow-lg">
        <img src="/images/about-5.jpg" alt="" class="h-full w-full object-cover" loading="lazy" />
      </div>
      <div class="absolute right-[5%] bottom-1/4 h-48 w-48 overflow-hidden rounded-full border-4 border-white shadow-lg">
        <img src="/images/about-6.jpg" alt="" class="h-full w-full object-cover" loading="lazy" />
      </div>
    </div>

    <!-- Mobile: 3 circles in a row below text -->
    <div class="mt-12 grid grid-cols-3 gap-4 lg:hidden">
      <img src="/images/about-1.jpg" alt="Spa tretman" class="aspect-square w-full rounded-full object-cover shadow-md" loading="lazy" />
      <img src="/images/about-4.jpg" alt="Hot stone masaža" class="aspect-square w-full translate-y-8 rounded-full object-cover shadow-md" loading="lazy" />
      <img src="/images/about-3.jpg" alt="Aromaterapija" class="aspect-square w-full rounded-full object-cover shadow-md" loading="lazy" />
    </div>

  </div>
</section>
