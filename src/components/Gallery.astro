---
// Gallery — 2×3 grid with rounded-xl
const images = [
  { src: '/images/gallery-waitingroom.png', alt: 'Čekaonica Salon Ranka' },
  { src: '/images/gallery-hallway.png',     alt: 'Hodnik Salon Ranka' },
  { src: '/images/gallery-cupping2.png',    alt: 'Cupping tretman u Salon Ranka' },
  { src: '/images/gallery-cupps.png',       alt: 'Čaše za cupping tretman' },
  { src: '/images/gallery-flower.png',      alt: 'Detalj salona — cvijeće' },
  { src: '/images/gallery-cactus.png',      alt: 'Detalj salona — kaktus' },
]
---
<section id="galerija" class="section-pt" aria-labelledby="gallery-heading">
  <div class="container-wide">

    <div class="mb-12 text-center fade-up">
      <h2 id="gallery-heading" class="heading-lg mb-2">Pogled iznutra</h2>
      <p class="mx-auto mt-4 max-w-2xl text-stone">
        Zakoračite u mir — istražite prostor u kojem se odvija opuštanje i obnova.
      </p>
    </div>

    <div class="grid grid-cols-2 gap-4 md:grid-cols-3" role="list" aria-label="Fotografije salona">
      {images.map((img) => (
        <div class="group relative overflow-hidden rounded-xl" role="listitem">
          <img
            src={img.src}
            alt={img.alt}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105 aspect-square"
            loading="lazy"
          />
        </div>
      ))}
    </div>

  </div>
</section>
