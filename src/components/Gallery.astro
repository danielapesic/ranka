---
// Gallery — simple 2×3 grid with rounded-xl (matches Revaya exactly)
const images = [
  {
    src: 'https://images.unsplash.com/photo-1507652313519-d4e9174996dd?auto=format&fit=crop&w=500&h=500&q=80',
    alt: 'Soba za masažu s toplim rasvjetom u Salon Ranka',
  },
  {
    src: 'https://images.unsplash.com/photo-1540555700478-4be289fbecef?auto=format&fit=crop&w=500&h=500&q=80',
    alt: 'Profesionalni tretman masaže',
  },
  {
    src: 'https://images.unsplash.com/photo-1515377905703-c4788e51af15?auto=format&fit=crop&w=500&h=500&q=80',
    alt: 'Aromaterapijske svjećice i ulja',
  },
  {
    src: 'https://images.unsplash.com/photo-1519823551278-64ac92734fb1?auto=format&fit=crop&w=500&h=500&q=80',
    alt: 'Esencijalna ulja za masažu',
  },
  {
    src: 'https://images.unsplash.com/photo-1600334129128-685c5582fd35?auto=format&fit=crop&w=500&h=500&q=80',
    alt: 'Relaksacijski tretman leđa',
  },
  {
    src: 'https://images.unsplash.com/photo-1600334089648-b0d9d3028eb2?auto=format&fit=crop&w=500&h=500&q=80',
    alt: 'Uređeni prostor za tretmane',
  },
]
---
<section id="galerija" class="section-pt" aria-labelledby="gallery-heading">
  <div class="container-wide">

    <div class="mb-12 text-center fade-up">
      <h2 id="gallery-heading" class="heading-lg mb-2">Pogled iznutra</h2>
      <p class="text-muted-foreground mx-auto mt-4 max-w-2xl text-stone">
        Zakoračite u mir — istražite prostor u kojem se odvija opuštanje i obnova.
      </p>
    </div>

    <!-- Equal-size 2×3 grid with rounded-xl (matches Revaya) -->
    <div class="grid grid-cols-2 gap-4 md:grid-cols-3" role="list" aria-label="Fotografije salona">
      {images.map((img) => (
        <div class="group relative overflow-hidden rounded-xl" role="listitem">
          <img
            src={img.src}
            alt={img.alt}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105 aspect-square"
            loading="lazy"
          />
        </div>
      ))}
    </div>

  </div>
</section>
