---
// Stats strip — centered, with star rating + circular icon badges (matches Revaya exactly)
---
<section class="border-b border-pebble bg-neutral-50 py-8 md:py-12" aria-label="Ključne prednosti">
  <div class="container-wide">
    <div class="grid grid-cols-1 gap-8 text-center sm:grid-cols-3 md:gap-12">

      <!-- Rating -->
      <div class="flex flex-col items-center justify-center gap-2">
        <div class="flex items-center gap-1 text-yellow-500" aria-label="Ocjena: 5 od 5 zvjezdica" role="img">
          {Array.from({ length: 5 }).map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/>
            </svg>
          ))}
        </div>
        <p class="text-lg font-semibold text-charcoal">4.9/5 Ocjena</p>
        <p class="text-sm text-stone">Na temelju 200+ recenzija</p>
      </div>

      <!-- Clients -->
      <div class="flex flex-col items-center justify-center gap-2">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-sage-50 text-sage-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <path d="M16 3.128a4 4 0 0 1 0 7.744"/>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
            <circle cx="9" cy="7" r="4"/>
          </svg>
        </div>
        <p class="text-lg font-semibold text-charcoal">500+ Zadovoljnih klijenata</p>
        <p class="text-sm text-stone">Pouzdani za premium tretmane</p>
      </div>

      <!-- Experience -->
      <div class="flex flex-col items-center justify-center gap-2">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-sage-50 text-sage-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/>
            <circle cx="12" cy="8" r="6"/>
          </svg>
        </div>
        <p class="text-lg font-semibold text-charcoal">10+ Godina iskustva</p>
        <p class="text-sm text-stone">Certificirani stručni terapeuti</p>
      </div>

    </div>
  </div>
</section>
