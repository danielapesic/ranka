---
// Footer — 4-column layout with logo, nav, services, and contact
---
<footer class="bg-charcoal text-white/80">
  <!-- Main footer columns -->
  <div class="container-wide py-20 lg:py-24">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">

      <!-- Col 1: Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="font-serif text-white text-xl tracking-wide mb-4 inline-block">
          Salon Ranka
        </a>
        <p class="text-sm leading-relaxed text-white/60 mt-3 max-w-xs">
          Profesionalna masaža u centru Zagreba. Iskusni terapeuti, mirno okruženje, tretmani prilagođeni vama.
        </p>
        <a
          href="tel:+38516110777"
          class="mt-6 inline-flex items-center gap-2 px-6 py-3 border border-white/30 text-white text-xs tracking-[0.16em] uppercase hover:border-white hover:text-white transition-colors duration-200"
          aria-label="Nazovite za posjet: +385 1 6110 777"
        >
          Nazovite za posjet
        </a>
      </div>

      <!-- Col 2: Salon links -->
      <div>
        <h3 class="text-white text-xs tracking-[0.2em] uppercase mb-6 font-sans font-medium">Salon</h3>
        <ul class="space-y-3.5" role="list">
          <li><a href="/" class="text-sm text-white/60 hover:text-white transition-colors duration-200">Početna</a></li>
          <li><a href="/#usluge" class="text-sm text-white/60 hover:text-white transition-colors duration-200">Usluge</a></li>
          <li><a href="/#galerija" class="text-sm text-white/60 hover:text-white transition-colors duration-200">Galerija</a></li>
          <li><a href="/cjenik" class="text-sm text-white/60 hover:text-white transition-colors duration-200">Cjenik</a></li>
          <li><a href="/kontakt" class="text-sm text-white/60 hover:text-white transition-colors duration-200">Kontakt</a></li>
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div>
        <h3 class="text-white text-xs tracking-[0.2em] uppercase mb-6 font-sans font-medium">Usluge</h3>
        <ul class="space-y-3.5" role="list">
          <li><a href="/#usluge" class="text-sm text-white/60 hover:text-white transition-colors duration-200">Masaža</a></li>
          <li><a href="/#usluge" class="text-sm text-white/60 hover:text-white transition-colors duration-200">Medicinska masaža</a></li>
          <li><a href="/#usluge" class="text-sm text-white/60 hover:text-white transition-colors duration-200">Kozmetika</a></li>
          <li><a href="/#usluge" class="text-sm text-white/60 hover:text-white transition-colors duration-200">Depilacija voskom</a></li>
        </ul>
      </div>

      <!-- Col 4: Contact -->
      <div>
        <h3 class="text-white text-xs tracking-[0.2em] uppercase mb-6 font-sans font-medium">Kontakt</h3>
        <address class="not-italic space-y-4">
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 shrink-0 text-white/40" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-sm text-white/60 leading-relaxed">
              Miramarska cesta 24<br />10000 Zagreb, Hrvatska
            </span>
          </div>

          <div class="flex items-center gap-3">
            <svg class="shrink-0 text-white/40" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-5.99-5.99 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:+38516110777" class="text-sm text-white/60 hover:text-white transition-colors duration-200">
              +385 1 6110 777
            </a>
          </div>

          <div class="flex items-center gap-3">
            <svg class="shrink-0 text-white/40" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:info@salonranka.hr" class="text-sm text-white/60 hover:text-white transition-colors duration-200">
              info@salonranka.hr
            </a>
          </div>
        </address>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container-wide py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/40">
        &copy; 2026 Salon Ranka. Sva prava pridržana.
      </p>
      <p class="text-xs text-white/30">
        Zagreb, Hrvatska
      </p>
    </div>
  </div>
</footer>
