---
// CTA banner — h-[90vh] full-image centered (matches Revaya exactly)
interface Props {
  headline?: string
  subhead?: string
  ctaLabel?: string
  ctaHref?: string
}

const {
  headline = 'Osvježite duh kroz naše tretmane',
  subhead = 'Pronađite ravnotežu tijela i uma uz tretmane osmišljene za odmor, obnovu i duboko opuštanje.',
  ctaLabel = 'Nazovite +385 1 6110 777',
  ctaHref = 'tel:+38516110777',
} = Astro.props
---
<section
  class="relative mt-35 flex h-[90vh] w-full items-center justify-center"
  aria-label="Poziv na akciju"
>
  <!-- Full-bleed background image -->
  <img
    src="https://images.unsplash.com/photo-1515377905703-c4788e51af15?auto=format&fit=crop&w=1920&q=85"
    alt=""
    class="absolute inset-0 h-full w-full object-cover object-center"
    loading="lazy"
    aria-hidden="true"
  />
  <!-- Overlay — matches Revaya's from-black/50 to-black/40 -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-black/50 to-black/40"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative max-w-3xl px-6 text-center text-white sm:px-0 fade-up">
    <h2 class="mb-4 text-4xl font-semibold md:text-6xl">{headline}</h2>
    <p class="mb-8 text-lg opacity-90 md:text-xl">{subhead}</p>
    <a
      href={ctaHref}
      class="btn-primary"
      aria-label={ctaLabel}
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-5.99-5.99 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      {ctaLabel}
    </a>
  </div>
</section>
