---
// How it works — 3 centered steps with circular icon badges (matches Revaya exactly)
const steps = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h12"/>
    </svg>`,
    title: '1. Odaberite uslugu',
    body: 'Pregledajte našu ponudu masaža i pronađite tretman koji odgovara vašem tijelu i potrebama.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-5.99-5.99 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>`,
    title: '2. Nazovite za termin',
    body: 'Dogovorite vrijeme koje vam odgovara — jednostavno, brzo, telefonom. Na raspolaganju smo za sva pitanja.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/>
      <path d="M20 2v4"/><path d="M22 4h-4"/><circle cx="4" cy="20" r="2"/>
    </svg>`,
    title: '3. Uživajte u tretmanu',
    body: 'Dođite u naš salon i prepustite se stručnim rukama naših terapeuta u opuštajućem okruženju.',
  },
]
---
<section class="section-pt" aria-labelledby="how-heading">
  <div class="container-wide">

    <!-- Centered header -->
    <div class="mb-12 text-center fade-up">
      <p class="eyebrow">Započnite svoj put do opuštanja</p>
      <h2 id="how-heading" class="heading-lg mb-2">
        Opuštanje u tri jednostavna koraka
      </h2>
    </div>

    <!-- 3 steps centered (Revaya pattern) -->
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {steps.map((step, i) => (
        <div class={`flex flex-col items-center text-center fade-up fade-up-delay-${i + 1}`}>
          <!-- Circular icon badge with sage-500 background -->
          <div class="mb-4 flex size-12 items-center justify-center rounded-full bg-sage-500 text-white">
            <Fragment set:html={step.icon} />
          </div>
          <h3 class="text-xl font-semibold text-charcoal">{step.title}</h3>
          <p class="mt-2 max-w-xs text-sm text-stone">{step.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
