---
// Why Us — centered cards with rounded-xl border (matches Revaya exactly)
const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/>
      <path d="M20 2v4"/><path d="M22 4h-4"/><circle cx="4" cy="20" r="2"/>
    </svg>`,
    title: 'Individualni tretmani',
    body: 'Svaki gost dobiva tretman pažljivo prilagođen njegovim potrebama, za učinkovito i smirujuće iskustvo bez kompromisa.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>`,
    title: 'Mirno okruženje',
    body: 'Naš salon je oaza spokoja — ugodan ambijent u kojem se opustite od trenutka kada zakoračite kroz vrata.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/>
    </svg>`,
    title: 'Stručni terapeuti',
    body: 'Iskusni profesionalci posvećeni vašem dobrostanju koriste provjerene tehnike i visokokvalitetna prirodna ulja.',
  },
]
---
<section class="section-pt" aria-labelledby="why-heading">
  <div class="container-wide">

    <!-- Header — centered (Revaya pattern) -->
    <div class="mb-10 text-center fade-up">
      <p class="eyebrow">Razlozi za odabir</p>
      <h2 id="why-heading" class="heading-lg mb-2">
        Po čemu se izdvajamo
      </h2>
    </div>

    <!-- Cards — rounded-xl, border, no shadow, centered content (Revaya) -->
    <div class="grid gap-10 md:grid-cols-3">
      {features.map((f, i) => (
        <div class={`rounded-xl border border-pebble bg-white py-6 text-center shadow-none flex flex-col gap-6 fade-up fade-up-delay-${i + 1}`}>
          <!-- Header area -->
          <div class="px-6">
            <div class="flex justify-center">
              <span class="text-sage-500 mb-4">
                <Fragment set:html={f.icon} />
              </span>
            </div>
            <h3 class="text-lg font-semibold text-charcoal">{f.title}</h3>
          </div>
          <!-- Content -->
          <div class="px-6">
            <p class="leading-relaxed text-stone text-sm">{f.body}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
