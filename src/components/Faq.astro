---
// FAQ — accordion (details/summary) + side card, clean border style
const faqs = [
  {
    q: 'Trebam li se naručiti unaprijed?',
    a: 'Da, sve tretmane potrebno je dogovoriti telefonom kako bismo vam osigurali termin koji vam najbolje odgovara. Preporučujemo rezervaciju nekoliko dana unaprijed, osobito za vikend termine.',
  },
  {
    q: 'Koliko traje tretman?',
    a: 'Tretmani obično traju između 30 i 90 minuta, ovisno o vrsti masaže. Točno trajanje dogovaramo prilikom rezervacije kako biste mogli isplanirati dan.',
  },
  {
    q: 'Kako mogu otkazati ili premjestiti termin?',
    a: 'Molimo vas da nas obavijestite najmanje 24 sata unaprijed putem telefona +385 1 6110 777. Razumijemo da se okolnosti ponekad mijenjaju — nastojat ćemo pronaći novo pogodno vrijeme.',
  },
  {
    q: 'Imate li poklon bonove?',
    a: 'Da, poklon bonove možete dogovoriti pozivom na +385 1 6110 777. Poklon bon je idealan za sve prigode — savršen dar za osobu koja zaslužuje odmor i opuštanje.',
  },
]
---
<section class="section-pt pb-24 lg:pb-32" aria-labelledby="faq-heading">
  <div class="container-wide">

    <div class="mb-12 fade-up">
      <p class="eyebrow">Imate pitanja</p>
      <h2 id="faq-heading" class="heading-lg">Česta pitanja</h2>
    </div>

    <div class="grid grid-cols-1 gap-12">

      <!-- Accordion -->
      <div class="space-y-2 fade-up">
        {faqs.map((item) => (
          <details class="border-b border-pebble">
            <summary class="flex items-center justify-between gap-4 py-5">
              <span class="font-medium text-lg text-charcoal pr-4">{item.q}</span>
              <svg
                class="summary-icon shrink-0 text-sage-500"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </summary>
            <div class="faq-body pb-5">
              <p class="text-sm text-stone leading-relaxed pr-8">{item.a}</p>
            </div>
          </details>
        ))}
      </div>

    </div>
  </div>
</section>
